{
  "name": "markpage",
  "private": true,
  "version": "0.3.2",
  "type": "module",
  "description": "Client-side Markdown to PDF converter",
  "license": "MIT",
  "author": "Yann Orlarey",
  "homepage": "https://markpage.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/orlarey/markpage.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update": "vitest run -u",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@expo-google-fonts/noto-sans-math": "^0.4.1",
    "@expo-google-fonts/noto-sans-symbols": "^0.4.1",
    "@expo-google-fonts/roboto-condensed": "^0.4.2",
    "@expo-google-fonts/roboto-mono": "^0.4.1",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/roboto-condensed": "^5.1.0",
    "@fontsource/roboto-mono": "^5.1.0",
    "codemirror": "^6.0.1",
    "ebnf2railroad": "^1.14.2",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "marked": "^14.1.3",
    "mathjax-full": "^3.2.2",
    "mermaid": "^11.14.0",
    "pagedjs": "^0.4.3",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/pdfmake": "^0.2.9",
    "@types/turndown": "^5.0.5",
    "happy-dom": "^20.9.0",
    "patch-package": "^8.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.6"
  }
}
