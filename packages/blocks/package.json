{
  "name": "@orlarey/blocks",
  "version": "0.1.1",
  "description": "Framework-agnostic renderers for markpage's fenced markdown blocks (chart, bda, category, adt, diff, tree) — self-contained HTML/SVG, no app dependencies.",
  "license": "MIT",
  "author": "Yann Orlarey",
  "homepage": "https://markpage.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orlarey/markpage.git",
    "directory": "packages/blocks"
  },
  "type": "module",
  "sideEffects": [
    "./src/index.ts",
    "./dist/index.js",
    "./styles/*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./styles/markpage.css"
  },
  "files": [
    "dist",
    "styles",
    "src",
    "SYNTAX.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  }
}
