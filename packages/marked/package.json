{
  "name": "@orlarey/marked",
  "version": "0.1.1",
  "description": "marked plugin for markpage's fenced blocks — `marked.use(markpageBlocks())`.",
  "license": "AGPL-3.0-or-later",
  "author": "Yann Orlarey",
  "homepage": "https://markpage.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orlarey/markpage.git",
    "directory": "packages/marked"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
