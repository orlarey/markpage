{
  "name": "@orlarey/markpage-render",
  "version": "0.1.0",
  "description": "markpage's Markdown render pipeline (fences, callouts, footnotes, refs) as a reusable marked setup — used by the web app and the VS Code preview.",
  "license": "MIT",
  "author": "Yann Orlarey",
  "homepage": "https://markpage.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orlarey/markpage.git",
    "directory": "packages/markpage-render"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./constructs.css": "./styles/constructs.css"
  },
  "files": [
    "dist",
    "src",
    "styles"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@mathjax/mathjax-asana-font": "^4.1.2",
    "@mathjax/mathjax-fira-font": "^4.1.2",
    "@mathjax/mathjax-newcm-font": "^4.1.2",
    "@mathjax/mathjax-stix2-font": "^4.1.2",
    "@mathjax/mathjax-tex-font": "^4.1.2",
    "@mathjax/src": "^4.1.2",
    "@orlarey/blocks": "^0.1.1",
    "ebnf2railroad": "^1.14.2",
    "highlight.js": "^11.11.1",
    "marked": ">=12",
    "mermaid": "^11.14.0"
  },
  "peerDependenciesMeta": {
    "@mathjax/mathjax-asana-font": { "optional": true },
    "@mathjax/mathjax-fira-font": { "optional": true },
    "@mathjax/mathjax-stix2-font": { "optional": true },
    "@mathjax/mathjax-tex-font": { "optional": true }
  },
  "publishConfig": {
    "access": "public"
  }
}
