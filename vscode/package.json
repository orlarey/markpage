{
  "name": "markpage-preview",
  "displayName": "markpage preview",
  "description": "Preview Markdown with all markpage extensions (fences, callouts, math, mermaid) — reuses @orlarey/markpage-render.",
  "version": "0.1.23",
  "publisher": "orlarey",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orlarey/markpage.git",
    "directory": "vscode"
  },
  "homepage": "https://github.com/orlarey/markpage/tree/main/vscode#readme",
  "bugs": {
    "url": "https://github.com/orlarey/markpage/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markpage.openPreview",
        "title": "Open markpage Preview",
        "category": "markpage",
        "icon": "$(open-preview)"
      },
      {
        "command": "markpage.togglePagination",
        "title": "Toggle Pagination (continuous ↔ A4 pages)",
        "category": "markpage",
        "icon": "$(book)"
      },
      {
        "command": "markpage.print",
        "title": "Print / Export PDF",
        "category": "markpage",
        "icon": "$(file-pdf)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markpage.openPreview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "markpage.openPreview",
          "when": "resourceExtname == .md || resourceExtname == .markdown",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "markpage.togglePagination"
        },
        {
          "command": "markpage.print"
        }
      ]
    },
    "keybindings": [
      {
        "command": "markpage.openPreview",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "editorLangId == markdown"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "node esbuild.mjs --production",
    "typecheck": "tsc --noEmit",
    "test:render": "node esbuild.mjs --production && node test/render-corpus.mjs",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "patch-package": "^8.0.0"
  },
  "dependencies": {
    "pagedjs": "^0.4.3"
  }
}
